# Authentication (choose one):

# Option 1: OAuth Token (for Claude Pro/Max subscribers)
# Run "claude setup-token" to obtain this token
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token_here

# Option 2: API Key (for developers and enterprises)
# Get from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Specify Claude model (defaults to claude-sonnet-4-5-20250929)
# MODEL=claude-sonnet-4-5-20250929
