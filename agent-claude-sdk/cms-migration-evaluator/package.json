{
  "name": "cms-migration-evaluator",
  "version": "1.0.0",
  "description": "Claude Agent SDK powered CMS migration quality evaluator",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist output/reports output/screenshots",
    "dev": "tsx src/cliEvaluator.ts",
    "start": "npm run build && node dist/cliEvaluator.js",
    "evaluate": "npm run dev"
