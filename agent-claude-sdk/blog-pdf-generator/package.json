{
  "name": "blog-pdf-generator",
  "version": "1.0.0",
  "description": "Claude Agent SDK powered blog PDF generator with self-validation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist output/deterministic output/agent-sdk output/specs",
    "dev:deterministic": "tsx src/cliDeterministic.ts",
    "dev:agent": "tsx src/cliSdk.ts",
    "dev:compare": "tsx src/cliComparison.ts",
    "dev": "npm run dev:deterministic",
    "start:deterministic": "npm run build && node dist/cliDeterministic.js",
    "start:agent": "npm run build && node dist/cliSdk.js",
    "start:compare": "npm run build && node dist/cliComparison.js",
    "start": "npm run start:deterministic",
    "generate": "npm run dev",
    "generate:specs": "tsx src/cliSpecGenerator.ts",
    "generate:specs:validate": "tsx src/cliSpecGenerator.ts --validate",
    "start:generate:specs": "npm run build && node dist/cliSpecGenerator.js"
  },
  "keywords": [
    "claude",
    "agent-sdk",
    "pdf",
    "blog",
    "puppeteer"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.30",
    "axios": "^1.7.9",
    "dotenv": "^16.4.5",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^23.11.1",
    "sharp": "^0.34.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
