{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Tool Response Schema",
  "description": "Standard response format for MCP tool calls",
  "type": "object",
  "required": ["content"],
  "properties": {
    "content": {
      "type": "array",
      "description": "Array of content blocks (text, images, etc.)",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["text", "image", "resource"]
          },
          "text": {
            "type": "string",
            "description": "Text content (for type: text)"
          }
        }
      },
      "minItems": 1
    },
    "isError": {
      "type": "boolean",
      "description": "Whether this is an error response",
      "default": false
    },
    "_meta": {
      "type": "object",
      "description": "Optional metadata for internal use (timing, etc.)",
      "properties": {
        "timing": {
          "type": "number",
          "description": "Duration in milliseconds"
        },
        "toolName": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    }
  }
}
