{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "save_dalive_content Response Schema",
  "description": "Response format for save_dalive_content tool",
  "type": "object",
  "required": ["success", "path", "timestamp", "contentLength", "urls"],
  "properties": {
    "success": {
      "type": "boolean",
      "description": "Whether the save operation succeeded"
    },
    "path": {
      "type": "string",
      "description": "da.live content path that was updated",
      "pattern": "^/source/"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when content was saved"
    },
    "contentLength": {
      "type": "integer",
      "description": "Length of saved HTML content in characters",
      "minimum": 0
    },
    "urls": {
      "type": "object",
      "description": "URLs returned by da.live for accessing the saved content",
      "required": ["editUrl", "contentUrl"],
      "properties": {
        "editUrl": {
          "type": "string",
          "format": "uri",
          "description": "Edit URL for the content in da.live"
        },
        "contentUrl": {
          "type": "string",
          "format": "uri",
          "description": "Direct content URL for CDN access"
        },
        "previewUrl": {
          "type": "string",
          "format": "uri",
          "description": "Preview URL (if available)"
        },
        "liveUrl": {
          "type": "string",
          "format": "uri",
          "description": "Live published URL (if available)"
        }
      }
    }
  }
}
