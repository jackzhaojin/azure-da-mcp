{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "get_dalive_content Response Schema",
  "description": "Response format for get_dalive_content tool",
  "type": "object",
  "required": ["htmlContent", "path", "lastModified", "contentLength"],
  "properties": {
    "htmlContent": {
      "type": "string",
      "description": "Raw HTML content from da.live"
    },
    "path": {
      "type": "string",
      "description": "da.live content path that was fetched",
      "pattern": "^/source/"
    },
    "lastModified": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when content was last modified"
    },
    "contentLength": {
      "type": "integer",
      "description": "Length of HTML content in characters",
      "minimum": 0
    }
  }
}
