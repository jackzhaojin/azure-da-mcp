{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "default": "Debug",
      "Function": "Debug",
      "Host.Results": "Debug",
      "Microsoft": "Debug"
    },
    "console": {
      "isEnabled": true
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "functionTimeout": "00:02:00",
  "http": {
    "routePrefix": "api",
    "cors": {
      "allowedOrigins": ["*"],
      "allowedMethods": ["GET", "POST", "OPTIONS"],
      "allowedHeaders": ["*"]
    }
  }
}