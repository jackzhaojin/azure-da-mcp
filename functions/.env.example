# E2E Test Configuration
# Copy this file to .env and fill in your actual tokens

# Da.live Bearer token (get from browser DevTools -> Network -> Authorization header)
# To get your token:
# 1. Open da.live in your browser
# 2. Open DevTools (F12 or Cmd+Option+I)
# 3. Go to Network tab
# 4. Reload the page
# 5. Click on any request to admin.da.live
# 6. Copy the Authorization header value (starts with "Bearer eyJ...")
DALIVE_BEARER_TOKEN=your-jwt-token-here

# LLM Provider Configuration
# Which LLM provider to use by default in /api/EditContent
# Options: 'claude' | 'gemini' | 'azure-ai-foundry'
LLM_PROVIDER=claude

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
GEMINI_API_KEY=your-gemini-api-key-here
AZURE_AI_FOUNDRY_API_KEY=your-azure-ai-foundry-key-here

# Default Models (used if not specified in request)
# Claude Sonnet 4.5 - Best for writing and MCP tools (premium option)
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Gemini 2.5 Pro - Free tier, good performance
GEMINI_MODEL=gemini-2.5-pro

# Azure OpenAI GPT-4o Mini - Most cost-effective option
AZURE_MODEL=gpt-5-mini

# Test configuration
# Path extracted from: https://admin.da.live/source/jackzhaojin/da-live-postal-2025-07/index-copy.html
# The path is everything after "admin.da.live" -> /source/jackzhaojin/da-live-postal-2025-07/index-copy.html
E2E_TEST_PATH=/source/jackzhaojin/da-live-postal-2025-07/index-copy.html
E2E_TEST_COMMAND=Make the hero section more concise
