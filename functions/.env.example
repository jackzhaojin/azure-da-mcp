# E2E Test Configuration
# Copy this file to .env and fill in your actual tokens

# Auth model — Adobe IMS Server-to-Server (S2S) OAuth.
# The function mints its own bearer tokens from these credentials at request time
# and forwards them to da.live, so you do NOT need to paste in a 24h JWT manually.
#
# Where to get the credentials:
#   developer.adobe.com → your Project → OAuth Server-to-Server credential
#   → Credential details → Client ID + "Retrieve client secret"
#
# Precedence at runtime (each MCP request):
#   1. Authorization: Bearer <token>       header — caller brings own identity
#   2. tools/call arg-bearer (Hack 2)      tool-arg fallback for hosts w/o headers
#   3. S2S minted (these env vars)         default
#
# DO NOT add DALIVE_BEARER_TOKEN here — the code no longer reads it. Any presence
# is misleading. The Adobe IMS S2S path replaces it entirely.
ADOBE_DEVELOPER_CONSOLE_CLIENT_ID=your-s2s-client-id
ADOBE_DEVELOPER_CONSOLE_CLIENT_SECRET=your-s2s-client-secret

# LLM Provider Configuration
# Which LLM provider to use by default in /api/EditContent
# Options: 'claude' | 'gemini' | 'azure-ai-foundry'
LLM_PROVIDER=claude

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
GEMINI_API_KEY=your-gemini-api-key-here
AZURE_AI_FOUNDRY_API_KEY=your-azure-ai-foundry-key-here
AZURE_AI_FOUNDRY_ENDPOINT=https://jack-mcp-azure-ai-foundary.services.ai.azure.com/

# Default Models (used if not specified in request)
# Claude Sonnet 4.5 - Best for writing and MCP tools (premium option)
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Gemini 2.5 Pro - Free tier, good performance
GEMINI_MODEL=gemini-2.5-pro

# Azure OpenAI GPT-4o Mini - Most cost-effective option
AZURE_MODEL=gpt-5-mini

# Test configuration
# Path extracted from: https://admin.da.live/source/jackzhaojin/da-live-postal-2025-07/index-copy.html
# The path is everything after "admin.da.live" -> /source/jackzhaojin/da-live-postal-2025-07/index-copy.html
E2E_TEST_PATH=/source/jackzhaojin/da-live-postal-2025-07/index-copy.html
E2E_TEST_COMMAND=Make the hero section more concise
