{
  "name": "agents",
  "version": "2.3.1",
  "private": true,
  "description": "A2A agent platform (v2.0) \u2014 one Express A2A server per agent (PRD: ai-docs/2026-06-05-a2a-agent-platform/; build report: ai-docs/2026-06-08-a2a-platform-v2.0/)",
  "type": "module",
  "workspaces": [
    "a2a-common",
    "eval-service",
    "content-gen",
    "migration-agent",
    "coordinator",
    "store-mcp",
    "e2e"
  ],
  "scripts": {
    "dev:eval": "npm run dev -w eval-service",
    "dev:content-gen": "npm run dev -w content-gen",
    "hello": "npm run hello -w coordinator",
    "test:e2e": "npm run test -w e2e",
    "typecheck": "tsc -p tsconfig.json && tsc -p eval-service/tsconfig.json",
    "test:live": "npm run test:live -w e2e",
    "dev:coordinator": "npm run dev -w coordinator",
    "dev:migration": "npm run dev -w migration-agent",
    "loop": "npm run loop -w coordinator --",
    "test:soak": "npm run test:soak -w e2e",
    "test:cloud": "npm run test:cloud -w e2e"
  },
  "engines": {
    "node": ">=20"
  }
}
