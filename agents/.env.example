# A2A agent platform — environment knobs.
# Agents read process.env directly (no dotenv). Load this file before `npm run dev:*`:
#   set -a; source .env; set +a
# Copy to .env and fill the secrets. .env is gitignored; .env.example is tracked.

# ── Cloudflare R2 (artifact storage) ────────────────────────────────────────
# When ALL of these are set, agents write artifacts to real R2 (public reads via
# r2.dev). Leave them unset for the local filesystem stand-in (zero-config dev/CI).
# Mint the two secrets once: dashboard → R2 → Manage API Tokens → Create API Token
#   → "Object Read & Write", scoped to the a2a-agents-artifacts bucket.  See docs/r2-setup.md
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=a2a-agents-artifacts
R2_PUBLIC_BASE=https://pub-ae7a7d0dbe1049c69ae60848bc58bfbf.r2.dev
R2_ACCOUNT_ID=957b2690e54ade4c335d8e395c5b69d5
# R2_S3_ENDPOINT=  # optional override; defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# ── Eval engine (agentic analysis) ──────────────────────────────────────────
EVAL_ENGINE=real            # real | stub
# CLAUDE_CODE_OAUTH_TOKEN=  # Claude Pro/Max OAuth — enables the agentic eval path
# ANTHROPIC_API_KEY=        # alternative to the OAuth token
EVAL_CONCURRENCY=2
BROWSER_PERMITS=3
EVAL_MAX_ATTEMPTS=3

# ── Mesh / edge auth ────────────────────────────────────────────────────────
# A2A_MESH_TOKEN=           # bearer required on /a2a between agents (unset = open, dev)
# A2A_EDGE_TOKEN=           # bearer for POST /hooks/{agent}/{skill} (defaults to mesh token)

# ── Migration agent ─────────────────────────────────────────────────────────
MIGRATION_DEFAULT_BACKEND=dryrun         # dryrun | makecom | sdk | opencode
#
# Make.com backend (cloud scenario; needs the cloudflared tunnel):
# MAKECOM_WEBHOOK_URL=      # Custom Webhook trigger URL from the Make.com scenario
# MIGRATION_CALLBACK_BASE=  # public base Make.com calls back on (the cloudflared tunnel host)
MAKECOM_TIMEOUT_MS=600000
#
# opencode / Kimi K2.6 backend (LOCAL, no Make.com) — backend:"opencode".
# Drives Kimi K2.6 headlessly via `opencode serve`, reusing the
# da-live-author-playwright skill + the da.live MCP + Playwright MCP.
# Requires MOONSHOT_API_KEY (the Kimi-For-Coding key) in the environment —
# it's exported from ~/.zshrc, so launch the agent from an interactive shell
# (or add it here). See agents/migration-agent/CLAUDE.md + references/kimi/.
# MOONSHOT_API_KEY=         # Kimi-For-Coding subscription key (usually from ~/.zshrc)
# OPENCODE_BIN=             # override path to the opencode binary (default ~/.opencode/bin/opencode)
# OPENCODE_MIGRATION_TIMEOUT_MS=1200000   # max wall time for one migration turn (default 20m)
#
# da.live MCP server the migration agent authors THROUGH (CRUD + preview-publish).
# Default = the DEPLOYED Azure functions/ server, which self-authenticates to
# da.live via its own S2S technical account — so NO secret is needed here.
DALIVE_MCP_URL=https://jack-mcp-azure-ai-function.azurewebsites.net/api/mcp-streamable
# To run the da.live MCP LOCALLY instead (e.g. to use YOUR Adobe S2S credential):
#   1. paste your S2S client id/secret into functions/local.settings.json:
#        "ADOBE_DEVELOPER_CONSOLE_CLIENT_ID":     "<your s2s client id>"
#        "ADOBE_DEVELOPER_CONSOLE_CLIENT_SECRET": "<your s2s client secret>"
#   2. cd functions && npm start            # serves :7071
#   3. point DALIVE_MCP_URL at it:
# DALIVE_MCP_URL=http://localhost:7071/api/mcp-streamable
#
# Optional: attribute da.live writes to a real user instead of the S2S technical
# account (an Adobe IMS user token from `npx github:adobe-rnd/da-auth-helper token`).
# Leave unset to use the server's S2S identity.
# DALIVE_BEARER_TOKEN=
#
# Optional live-test target (agents/e2e/tests-live/opencode-migration.live.test.ts).
# A da.live owner/site the S2S technical account can WRITE to. Unset → test skips.
# DALIVE_TEST_OWNER=
# DALIVE_TEST_SITE=
# DALIVE_TEST_SOURCE_URL=https://example.com

# ── Coordinator (mesh wiring + dashboard) ───────────────────────────────────
EVAL_AGENT_URL=http://localhost:4001
CONTENT_GEN_URL=http://localhost:4002
MIGRATION_AGENT_URL=http://localhost:4003
COORD_FANOUT_CONCURRENCY=4
# The coordinator serves its own Next.js dashboard on the SAME port (:4004/):
# trigger runs, live activity feed, branch grid, variance. Set off to disable.
# COORDINATOR_UI=off

# ── Coordinator dashboard auth (Google SSO via Auth.js v5) ──────────────────
# When BOTH Google vars are set, the dashboard pages + /api/* require a Google
# sign-in (locally AND behind the tunnel) and runs are tied to the signed-in
# user (runs.user_email). Unset = open dashboard (dev default).
# OAuth client (Web application) needs BOTH redirect URIs:
#   http://localhost:4004/api/auth/callback/google
#   https://content-factor-dash.xpri.ai/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_SECRET=              # JWT session signing key: openssl rand -base64 33
# AUTH_ALLOWED_EMAILS=      # optional comma-separated allowlist; unset = any Google account

# ── UI (legacy thin dashboard, agents/ui :3000) ─────────────────────────────
# UI_PASSWORD=              # shared-secret login for agents/ui
# COORDINATOR_DB=           # path to the coordinator's SQLite store (runs dashboard)
