# A2A agent platform — environment knobs.
# Agents read process.env directly (no dotenv). Load this file before `npm run dev:*`:
#   set -a; source .env; set +a
# Copy to .env and fill the secrets. .env is gitignored; .env.example is tracked.

# ── Cloudflare R2 (artifact storage) ────────────────────────────────────────
# When ALL of these are set, agents write artifacts to real R2 (public reads via
# r2.dev). Leave them unset for the local filesystem stand-in (zero-config dev/CI).
# Mint the two secrets once: dashboard → R2 → Manage API Tokens → Create API Token
#   → "Object Read & Write", scoped to the a2a-agents-artifacts bucket.  See docs/r2-setup.md
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=a2a-agents-artifacts
R2_PUBLIC_BASE=https://pub-ae7a7d0dbe1049c69ae60848bc58bfbf.r2.dev
R2_ACCOUNT_ID=957b2690e54ade4c335d8e395c5b69d5
# R2_S3_ENDPOINT=  # optional override; defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# ── Eval engine (agentic analysis) ──────────────────────────────────────────
EVAL_ENGINE=real            # real | stub
# CLAUDE_CODE_OAUTH_TOKEN=  # Claude Pro/Max OAuth — enables the agentic eval path
# ANTHROPIC_API_KEY=        # alternative to the OAuth token
EVAL_CONCURRENCY=2
BROWSER_PERMITS=3
EVAL_MAX_ATTEMPTS=3

# ── Mesh / edge auth ────────────────────────────────────────────────────────
# A2A_MESH_TOKEN=           # bearer required on /a2a between agents (unset = open, dev)
# A2A_EDGE_TOKEN=           # bearer for POST /hooks/{agent}/{skill} (defaults to mesh token)

# ── Migration agent → Make.com ──────────────────────────────────────────────
MIGRATION_DEFAULT_BACKEND=dryrun         # dryrun | makecom | sdk
# MAKECOM_WEBHOOK_URL=      # Custom Webhook trigger URL from the Make.com scenario
# MIGRATION_CALLBACK_BASE=  # public base Make.com calls back on (the cloudflared tunnel host)
MAKECOM_TIMEOUT_MS=600000

# ── Coordinator (mesh wiring) ───────────────────────────────────────────────
EVAL_AGENT_URL=http://localhost:4001
CONTENT_GEN_URL=http://localhost:4002
MIGRATION_AGENT_URL=http://localhost:4003
COORD_FANOUT_CONCURRENCY=4

# ── UI ──────────────────────────────────────────────────────────────────────
# UI_PASSWORD=              # shared-secret login for agents/ui
# COORDINATOR_DB=           # path to the coordinator's SQLite store (runs dashboard)
