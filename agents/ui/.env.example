# Shared-secret login (scaffold — open question #6 picks the real mechanism by M4).
# Unset = auth disabled (local dev only).
UI_PASSWORD=

# Where the coordinator's A2A server lives (trigger submits coordinate.run here)
COORDINATOR_URL=http://localhost:4004

# Coordinator store (runs table). Default resolves from agents/ui/ to the sibling package.
COORDINATOR_DB=../coordinator/data/store.db

# Mesh bearer token, if the mesh runs with A2A_MESH_TOKEN set
A2A_MESH_TOKEN=
