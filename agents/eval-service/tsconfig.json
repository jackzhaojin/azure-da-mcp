{
  // Mirrors the frozen content-authoring-eval tsconfig (bundler resolution,
  // extensionless imports) so the copied engine compiles verbatim — we adapt
  // the config to the copy, not 22 frozen files to NodeNext. tsx resolves the
  // same way at runtime. New eval-service code follows the same style.
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["src/engine/*"],
      "@/types/*": ["src/engine/types/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
