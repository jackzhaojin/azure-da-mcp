body:json {
  {
    "command": "Change our deliveries with care. Another to our deliveries with care. Anotherabcdefgh",
    "path": "/source/jackzhaojin/da-live-postal-2025-07/index-copy.html"
  }
}

assert {
  res.status: eq 200
  res.body.requestId: isDefined
  res.body.editedHtmlLength: isDefined
  res.body.explanation: isDefined
  res.body.reasoning: isDefined
  res.body.timing: isDefined
  res.body.mcpToolCalls: isDefined
}

tests {
  test("Response has request ID", function() {
    expect(res.body.requestId).to.be.a('string');
  });
  
  test("MCP tools were called", function() {
    expect(res.body.mcpToolCalls).to.be.an('array');
    expect(res.body.mcpToolCalls.length).to.be.greaterThan(0);
  });
  
  test("get_dalive_content was called", function() {
    const toolNames = res.body.mcpToolCalls.map(call => call.toolName);
    expect(toolNames).to.include('get_dalive_content');
  });
  
  test("save_dalive_content was called", function() {
    const toolNames = res.body.mcpToolCalls.map(call => call.toolName);
    expect(toolNames).to.include('save_dalive_content');
  });
  
  test("Timing information is present", function() {
    expect(res.body.timing).to.have.property('total');
    expect(res.body.timing).to.have.property('llm_call');
    expect(res.body.timing).to.have.property('mcp_get_content');
    expect(res.body.timing).to.have.property('mcp_save_content');
  });
  
  test("LLM provided explanation", function() {
    expect(res.body.explanation).to.be.a('string');
    expect(res.body.explanation.length).to.be.greaterThan(0);
  });
  
  test("LLM provided reasoning", function() {
    expect(res.body.reasoning).to.be.a('string');
    expect(res.body.reasoning.length).to.be.greaterThan(0);
  });
}

docs {
  # EditContentFunction - MCP-enabled AI Content Editing
  
  This endpoint triggers the AI-assisted content editing workflow using Model Context Protocol (MCP).
  
  ## Workflow
  1. LLM autonomously calls `get_dalive_content` MCP tool to fetch HTML from da.live
  2. LLM generates edited HTML based on the command
  3. LLM autonomously calls `save_dalive_content` MCP tool to save changes
  
  ## Request Body
  - `command`: Natural language editing instruction (e.g., "Make the hero section more concise")
  - `path`: da.live content path (e.g., "/source/owner/site/page.html")
  - `metadata` (optional): Additional context for the LLM
  
  ## Response
  - `requestId`: Unique identifier for this request
  - `editedHtmlLength`: Length of the edited HTML in characters
  - `explanation`: LLM's explanation of what was changed
  - `reasoning`: LLM's reasoning for the changes
  - `timing`: Performance breakdown (total, llm_call, mcp_get_content, mcp_save_content)
  - `mcpToolCalls`: Array of MCP tool calls made (toolName, parameters, result, duration, status)
  
  ## Authentication
  Bearer token is passed to MCP tools for da.live API authentication.
  
  ## Typical Response Time
  ~30-50 seconds (LLM multi-turn conversation + MCP tool calls)
}
