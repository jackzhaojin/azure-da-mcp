# Dockerfile.debug - Debug build with verbose logging and source maps
# Based on production Dockerfile with debugging enhancements

FROM node:20-slim AS base
WORKDIR /app

# Install system dependencies (same as production)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 \
    libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 libcairo2 \
    libasound2 libatspi2.0-0 ca-certificates fonts-liberation \
    libappindicator3-1 libu2f-udev xdg-utils imagemagick curl && \
    npm install -g lighthouse@12.2.1 pa11y@8.0.0 \
    @anthropic-ai/claude-code @modelcontextprotocol/server-filesystem @playwright/mcp && \
    npm cache clean --force && \
    apt-get autoremove -y && apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Create non-root user
RUN useradd -m -s /bin/bash appuser

# Copy application files
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Pre-install chromium browsers (ARM64 compatible)
# Playwright 1.49+ requires chromium-headless-shell to be installed separately
# from full chromium — both are needed because launch({ headless: true }) uses the shell.
RUN /usr/local/lib/node_modules/@playwright/mcp/node_modules/.bin/playwright install chromium chromium-headless-shell && \
    mkdir -p /home/appuser/.cache/ms-playwright && \
    cp -r /root/.cache/ms-playwright/* /home/appuser/.cache/ms-playwright/ && \
    cd /home/appuser/.cache/ms-playwright && \
    ln -s chromium-1205 chromium-1200 && \
    ln -s chromium_headless_shell-1205 chromium_headless_shell-1200 && \
    chown -R appuser:appuser /home/appuser/.cache && \
    rm -rf /root/.cache/ms-playwright

# Setup directories
RUN mkdir -p /home/appuser/.claude /app/public/screenshots /tmp/debug-logs && \
    chown -R appuser:appuser /home/appuser /app /tmp/debug-logs

# Copy entrypoint script
COPY --chown=appuser:appuser docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

USER appuser

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV HOME=/home/appuser
ENV PLAYWRIGHT_BROWSERS_PATH=/home/appuser/.cache/ms-playwright
ENV NODE_ENV=production

EXPOSE 3000 9229

HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/api/evaluate', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["node", "--inspect=0.0.0.0:9229", "server.js"]
