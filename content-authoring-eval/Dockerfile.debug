# Dockerfile.debug - Simplified Single-Stage Build for Agent SDK Debugging
# Phase 25.1: Strip away all optimizations to isolate Agent SDK containerization issue
# Philosophy: "Make it work, then make it right, then make it fast." - Kent Beck

FROM node:20
WORKDIR /app

# Install ALL system dependencies (no --no-install-recommends for debugging)
RUN apt-get update && apt-get install -y \
    chromium \
    chromium-driver \
    imagemagick \
    curl \
    git \
    ca-certificates \
    fonts-liberation \
    # Keep chromium dependencies for Playwright
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libatspi2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy package files and install ALL dependencies (dev + prod)
COPY package*.json ./
RUN npm ci

# Install Playwright with browsers (as root, full install)
RUN npx playwright install chromium --with-deps

# Install global CLI tools
RUN npm install -g \
    @anthropic-ai/claude-code \
    lighthouse@12.2.1 \
    pa11y@8.0.0

# DEBUG: Check what MCP server packages are available
RUN echo "=== Checking for MCP servers ===" && \
    npm list -g --depth=0 || true && \
    echo "=== Checking for @playwright/mcp ===" && \
    npm list -g @playwright/mcp 2>&1 || echo "Not found globally" && \
    echo "=== Checking /usr/local/lib/node_modules ===" && \
    ls -la /usr/local/lib/node_modules/ || true

# DEBUG: Install MCP servers globally for Agent SDK
# Based on Phase 25 production Dockerfile attempts
RUN npm install -g @modelcontextprotocol/server-filesystem || \
    echo "WARNING: @modelcontextprotocol/server-filesystem not available" && \
    npm install -g @playwright/mcp || \
    echo "WARNING: @playwright/mcp not available"

# DEBUG: Verify MCP server binaries after install
RUN echo "=== Verifying MCP server binaries ===" && \
    ls -la /usr/local/bin/ | grep mcp || echo "No MCP binaries found in /usr/local/bin" && \
    echo "=== Checking node_modules for MCP ===" && \
    find /usr/local/lib/node_modules -name "*mcp*" -type d 2>/dev/null | head -20 || true

# Copy application source
COPY . .

# Build Next.js (production build)
RUN npm run build

# Environment variables
ENV NODE_ENV=production
ENV PORT=3000
ENV PLAYWRIGHT_BROWSERS_PATH=/root/.cache/ms-playwright

# DEBUG: Add verbose Node.js logging for Agent SDK (DISABLED for Phase 25.3)
# ENV NODE_DEBUG=*
# ENV DEBUG=*

# PHASE 25.2: Accept OAuth token as build argument and set as env var
ARG CLAUDE_CODE_OAUTH_TOKEN
ENV CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN}

# PHASE 25.3: Create non-root user for Claude CLI
# Claude CLI refuses --dangerously-skip-permissions when running as root
RUN useradd -m -s /bin/bash appuser && \
    chown -R appuser:appuser /app

# PHASE 25.3: Create .claude.json with OAuth account info for CLI authentication
# This tells the `claude` CLI WHO is authenticated (account, email, org)
# The OAuth token itself comes from CLAUDE_CODE_OAUTH_TOKEN env var
# NOTE: mcpServers is empty because we configure MCP servers programmatically in agentic.ts
RUN mkdir -p /home/appuser/.claude && \
    echo '{"oauthAccount":{"accountUuid":"434c49a7-3afc-4399-9a7c-c4fea4785c7b","emailAddress":"jackzhaojin@gmail.com","organizationUuid":"170f4c50-03d8-42fc-82b3-dd0a83e476ae"},"mcpServers":{}}' > /home/appuser/.claude.json && \
    chown -R appuser:appuser /home/appuser/.claude

# Run as non-root user (REQUIRED for --dangerously-skip-permissions to work)
USER appuser
ENV HOME=/home/appuser

EXPOSE 3000

# DEBUG: Start with explicit error logging
CMD ["sh", "-c", "echo '=== Starting Next.js server ===' && echo 'Node version:' && node --version && echo 'Environment:' && env | grep -E '(NODE_ENV|CLAUDE|PLAYWRIGHT)' && npm start 2>&1 | tee /tmp/server.log"]
