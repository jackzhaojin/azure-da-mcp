# Claude API Configuration (PHASE 25: Use API Key for Production)
# Get your API key from https://console.anthropic.com/
# IMPORTANT: Agent SDK requires ANTHROPIC_API_KEY (not CLAUDE_CODE_OAUTH_TOKEN)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-API-KEY-HERE

# Optional: Specify Claude model (defaults to claude-haiku-4-5-20250929)
# Recommended: claude-sonnet-4-5-20250929 for production quality
# Alternative: claude-haiku-4-5-20250929 for cost efficiency
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
