# Docker Environment Variables Template
# Copy this to .env.docker and fill in your values
# IMPORTANT: Never commit .env.docker with real credentials!

# Claude Code OAuth Token (required)
# Get this from: https://claude.ai/settings
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-YOUR-TOKEN-HERE

# Claude Account Info (required for Agent SDK in Docker)
# These are NOT secrets, just account identifiers
# Find these in ~/.claude.json after running `claude --version`
CLAUDE_ACCOUNT_UUID=your-account-uuid-here
CLAUDE_EMAIL=your-email@example.com
CLAUDE_ORG_UUID=your-org-uuid-here

# Claude Model (optional, defaults to Sonnet 4.5)
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Node Environment (optional, defaults to production)
NODE_ENV=production
