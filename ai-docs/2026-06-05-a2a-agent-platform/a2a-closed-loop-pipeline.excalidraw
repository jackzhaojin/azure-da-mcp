{
  "type": "excalidraw",
  "version": 2,
  "source": "https://excalidraw.com",
  "elements": [
    { "id": "an_title", "type": "text", "x": 250, "y": 40, "width": 960, "height": 30, "text": "Intelligent content orchestrator — enters and exits at any stage", "originalText": "Intelligent content orchestrator — enters and exits at any stage", "fontSize": 22, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": null, "lineHeight": 1.25 },
    { "id": "an_sub", "type": "text", "x": 300, "y": 82, "width": 860, "height": 22, "text": "not a fixed generate → migrate → evaluate pipeline; it decides what work is needed and stops when the goal is met", "originalText": "not a fixed generate → migrate → evaluate pipeline; it decides what work is needed and stops when the goal is met", "fontSize": 15, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": null, "lineHeight": 1.25 },

    { "id": "an_inlbl", "type": "text", "x": 60, "y": 188, "width": 250, "height": 20, "text": "any intent · any starting state", "originalText": "any intent · any starting state", "fontSize": 14, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": null, "lineHeight": 1.25 },

    { "id": "inp1", "type": "rectangle", "x": 60, "y": 220, "width": 250, "height": 70, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "roundness": { "type": 3 }, "boundElements": [{ "type": "text", "id": "inp1t" }, { "id": "a_in1", "type": "arrow" }] },
    { "id": "inp1t", "type": "text", "x": 65, "y": 233, "width": 240, "height": 45, "text": "net-new\n→ start at Generate", "originalText": "net-new\n→ start at Generate", "fontSize": 15, "fontFamily": 5, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": "inp1", "lineHeight": 1.25 },
    { "id": "inp2", "type": "rectangle", "x": 60, "y": 320, "width": 250, "height": 70, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "roundness": { "type": 3 }, "boundElements": [{ "type": "text", "id": "inp2t" }, { "id": "a_in2", "type": "arrow" }] },
    { "id": "inp2t", "type": "text", "x": 65, "y": 333, "width": 240, "height": 45, "text": "content exists\n→ start at Migrate", "originalText": "content exists\n→ start at Migrate", "fontSize": 15, "fontFamily": 5, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": "inp2", "lineHeight": 1.25 },
    { "id": "inp3", "type": "rectangle", "x": 60, "y": 420, "width": 250, "height": 70, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "roundness": { "type": 3 }, "boundElements": [{ "type": "text", "id": "inp3t" }, { "id": "a_in3", "type": "arrow" }] },
    { "id": "inp3t", "type": "text", "x": 65, "y": 433, "width": 240, "height": 45, "text": "already migrated\n→ start at Evaluate", "originalText": "already migrated\n→ start at Evaluate", "fontSize": 15, "fontFamily": 5, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": "inp3", "lineHeight": 1.25 },

    { "id": "hub", "type": "rectangle", "x": 410, "y": 290, "width": 280, "height": 180, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "roundness": { "type": 3 }, "boundElements": [{ "type": "text", "id": "hubt" }, { "id": "a_in1", "type": "arrow" }, { "id": "a_in2", "type": "arrow" }, { "id": "a_in3", "type": "arrow" }, { "id": "a_gen", "type": "arrow" }, { "id": "a_mig", "type": "arrow" }, { "id": "a_eval", "type": "arrow" }] },
    { "id": "hubt", "type": "text", "x": 415, "y": 325, "width": 270, "height": 110, "text": "Orchestrator\nintelligent A2A client\n\ndecides which stages run", "originalText": "Orchestrator\nintelligent A2A client\n\ndecides which stages run", "fontSize": 18, "fontFamily": 5, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": "hub", "lineHeight": 1.25 },

    { "id": "capGen", "type": "rectangle", "x": 800, "y": 205, "width": 260, "height": 100, "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "roundness": { "type": 3 }, "boundElements": [{ "type": "text", "id": "capGent" }, { "id": "a_gen", "type": "arrow" }] },
    { "id": "capGent", "type": "text", "x": 805, "y": 232, "width": 250, "height": 45, "text": "Generate\nContent-Gen · brief / source", "originalText": "Generate\nContent-Gen · brief / source", "fontSize": 16, "fontFamily": 5, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": "capGen", "lineHeight": 1.25 },
    { "id": "capMig", "type": "rectangle", "x": 800, "y": 335, "width": 260, "height": 100, "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "roundness": { "type": 3 }, "boundElements": [{ "type": "text", "id": "capMigt" }, { "id": "a_mig", "type": "arrow" }] },
    { "id": "capMigt", "type": "text", "x": 805, "y": 362, "width": 250, "height": 45, "text": "Migrate\nauthor + validate", "originalText": "Migrate\nauthor + validate", "fontSize": 16, "fontFamily": 5, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": "capMig", "lineHeight": 1.25 },
    { "id": "capEval", "type": "rectangle", "x": 800, "y": 465, "width": 260, "height": 100, "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "roundness": { "type": 3 }, "boundElements": [{ "type": "text", "id": "capEvalt" }, { "id": "a_eval", "type": "arrow" }, { "id": "a_agg", "type": "arrow" }] },
    { "id": "capEvalt", "type": "text", "x": 805, "y": 492, "width": 250, "height": 45, "text": "Evaluate\n4-dim scores", "originalText": "Evaluate\n4-dim scores", "fontSize": 16, "fontFamily": 5, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": "capEval", "lineHeight": 1.25 },

    { "id": "agg", "type": "rectangle", "x": 1130, "y": 465, "width": 260, "height": 100, "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "dashed", "roughness": 1, "opacity": 100, "roundness": { "type": 3 }, "boundElements": [{ "type": "text", "id": "aggt" }, { "id": "a_agg", "type": "arrow" }] },
    { "id": "aggt", "type": "text", "x": 1135, "y": 492, "width": 250, "height": 45, "text": "Aggregate · variance\n(only on fanOut Nx)", "originalText": "Aggregate · variance\n(only on fanOut Nx)", "fontSize": 15, "fontFamily": 5, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": "agg", "lineHeight": 1.25 },

    { "id": "a_in1", "type": "arrow", "x": 312, "y": 255, "width": 96, "height": 85, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "points": [[0, 0], [96, 85]], "startBinding": { "elementId": "inp1", "focus": 0, "gap": 4 }, "endBinding": { "elementId": "hub", "focus": 0, "gap": 4 }, "startArrowhead": null, "endArrowhead": "arrow" },
    { "id": "a_in2", "type": "arrow", "x": 312, "y": 355, "width": 96, "height": 25, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "points": [[0, 0], [96, 25]], "startBinding": { "elementId": "inp2", "focus": 0, "gap": 4 }, "endBinding": { "elementId": "hub", "focus": 0, "gap": 4 }, "startArrowhead": null, "endArrowhead": "arrow" },
    { "id": "a_in3", "type": "arrow", "x": 312, "y": 455, "width": 96, "height": 35, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "points": [[0, 0], [96, -35]], "startBinding": { "elementId": "inp3", "focus": 0, "gap": 4 }, "endBinding": { "elementId": "hub", "focus": 0, "gap": 4 }, "startArrowhead": null, "endArrowhead": "arrow" },

    { "id": "a_gen", "type": "arrow", "x": 692, "y": 330, "width": 106, "height": 75, "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "points": [[0, 0], [106, -75]], "startBinding": { "elementId": "hub", "focus": 0, "gap": 4 }, "endBinding": { "elementId": "capGen", "focus": 0, "gap": 4 }, "startArrowhead": "arrow", "endArrowhead": "arrow" },
    { "id": "a_mig", "type": "arrow", "x": 692, "y": 382, "width": 106, "height": 3, "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "points": [[0, 0], [106, 3]], "startBinding": { "elementId": "hub", "focus": 0, "gap": 4 }, "endBinding": { "elementId": "capMig", "focus": 0, "gap": 4 }, "startArrowhead": "arrow", "endArrowhead": "arrow" },
    { "id": "a_eval", "type": "arrow", "x": 692, "y": 432, "width": 106, "height": 83, "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "points": [[0, 0], [106, 83]], "startBinding": { "elementId": "hub", "focus": 0, "gap": 4 }, "endBinding": { "elementId": "capEval", "focus": 0, "gap": 4 }, "startArrowhead": "arrow", "endArrowhead": "arrow" },
    { "id": "a_agg", "type": "arrow", "x": 1062, "y": 515, "width": 66, "height": 0, "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "dashed", "roughness": 1, "opacity": 100, "points": [[0, 0], [66, 0]], "startBinding": { "elementId": "capEval", "focus": 0, "gap": 4 }, "endBinding": { "elementId": "agg", "focus": 0, "gap": 4 }, "startArrowhead": null, "endArrowhead": "arrow" },

    { "id": "an_loop", "type": "text", "x": 705, "y": 168, "width": 320, "height": 20, "text": "invoke ⇄ result · loops as needed", "originalText": "invoke ⇄ result · loops as needed", "fontSize": 14, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#6741d9", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": null, "lineHeight": 1.25 },
    { "id": "an_stop", "type": "text", "x": 410, "y": 482, "width": 280, "height": 20, "text": "may stop after any stage when the goal is met", "originalText": "may stop after any stage when the goal is met", "fontSize": 13, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": null, "lineHeight": 1.25 },

    { "id": "an_routes", "type": "text", "x": 410, "y": 585, "width": 720, "height": 160, "text": "Example routes the orchestrator picks on its own:\n•  no content        →  Generate → Migrate → Evaluate\n•  content exists     →  Migrate → Evaluate\n•  already migrated   →  Evaluate only\n•  author net-new     →  Generate → Migrate  (stop)\n•  fanOut Nx          →  repeat branches → Aggregate variance", "originalText": "Example routes the orchestrator picks on its own:\n•  no content        →  Generate → Migrate → Evaluate\n•  content exists     →  Migrate → Evaluate\n•  already migrated   →  Evaluate only\n•  author net-new     →  Generate → Migrate  (stop)\n•  fanOut Nx          →  repeat branches → Aggregate variance", "fontSize": 16, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "containerId": null, "lineHeight": 1.25 }
  ],
  "appState": {
    "gridSize": 20,
    "viewBackgroundColor": "#ffffff"
  },
  "files": {}
}
